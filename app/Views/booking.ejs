<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aplikasi Pemesanan Kereta</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style/booking.css">
</head>

<body>


  <div class="navbar">
    <button class="back-btn" onclick="goBack()">←</button>
    <div class="logo-box">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M4 4h16c1.1 0 2 .9 2 2v8c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v8h16V6H4zm2 9h2v2H6v-2zm10 0h2v2h-2v-2zM8 8h8v4H8V8z" />
      </svg>
    </div>
    <h1>Aplikasi Pemesanan Kereta</h1>
  </div>


  <div class="toast" id="toast"></div>


  <div class="screen active" id="screen-booking">
    <div class="booking-container">

      <div class="booking-header">
        <div>
          <h2>Book Your Ticket</h2>
          <p id="stepLabel">Step 1 of 4</p>
        </div>
        <div class="steps-row" id="stepsRow"></div>
      </div>


      <div class="card step-content" id="step1">
        <div class="card-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4" />
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
          </svg>
          Passenger Information
        </div>

        <label>Full Name</label>
        <input type="text" id="inp-name" placeholder="Enter your full name">

        <label>Number of Passengers</label>
        <input type="number" id="inp-passengers" value="1" min="1" max="10">

        <div class="grid-2">
          <div>
            <label>Origin</label>
            <select id="inp-origin">
              <option value="">Select origin</option>
              <option>Medan</option>
              <option>Tebing Tinggi</option>
              <option>Pematang Siantar</option>
              <option>Kisaran</option>
              <option>Rantau Prapat</option>
            </select>
          </div>
          <div>
            <label>Destination</label>
            <select id="inp-destination">
              <option value="">Select destination</option>
              <option>Medan</option>
              <option>Tebing Tinggi</option>
              <option>Pematang Siantar</option>
              <option>Kisaran</option>
              <option>Rantau Prapat</option>
            </select>
          </div>
        </div>

        <label>Departure Date</label>
        <input type="date" id="inp-date">
      </div>


      <div class="card step-content" id="step2" style="display:none">
        <div class="card-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3" />
            <path
              d="M12 2v2m0 16v2M2 12h2m16 0h2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41" />
          </svg>
          Select Class
        </div>


        <div id="routeInfoBadge"
          style="display:none;align-items:center;gap:8px;background:#EFF6FF;border:1px solid #BFDBFE;border-radius:10px;padding:10px 14px;margin-bottom:16px;font-size:0.83rem;color:#1D4ED8;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span id="routeInfoText"></span>
        </div>

        <div class="class-option" data-class="Economy" onclick="selectClass(this)">
          <div class="class-info"><b>Economy</b>
            <p>1x base price per person</p>
          </div>
          <div class="class-price" id="price-Economy">Rp -</div>
        </div>

        <div class="class-option" data-class="Business" onclick="selectClass(this)">
          <div class="class-info"><b>Business</b>
            <p>1.5x base price per person</p>
          </div>
          <div class="class-price" id="price-Business">Rp -</div>
        </div>

        <div class="class-option" data-class="Executive" onclick="selectClass(this)">
          <div class="class-info"><b>Executive</b>
            <p>2x base price per person</p>
          </div>
          <div class="class-price" id="price-Executive">Rp -</div>
        </div>
      </div>

      <div class="card step-content" id="step3" style="display:none">
        <div class="card-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 10V6a2 2 0 012-2h10a2 2 0 012 2v4M3 18h18M5 10h14l1 8H4l1-8z" />
          </svg>
          Select Seats (<span id="seatCount">0</span>/<span id="seatMax">1</span>)
        </div>
        <div class="seats-grid" id="seatsGrid"></div>
      </div>

      <div class="card step-content" id="step4" style="display:none">
        <div class="card-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <path d="M2 10h20" />
          </svg>
          Booking Summary
        </div>
        <div id="bookingSummary"></div>
        <div class="summary-total">
          <span>Total Price</span>
          <span class="total-price" id="totalPrice">Rp 0</span>
        </div>
      </div>

      <div class="actions" id="bookingActions">
        <button class="btn-prev" id="prevBtn" onclick="prevStep()" style="display:none">Previous</button>
        <button class="btn-next" id="nextBtn" onclick="nextStep()">Next</button>
      </div>

    </div>
  </div>

  <div class="screen" id="screen-payment">
    <div class="payment-container">
      <div class="payment-title">
        <h2>Payment</h2>
        <p>Complete your payment to confirm booking</p>
      </div>

      <div class="payment-grid">
        <div class="payment-methods">
          <div class="card">
            <h3>Select Payment Method</h3>

            <div class="method-option" data-method="QRIS" onclick="selectMethod(this)">
              <div class="method-dot"></div>
              <div class="method-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="5" width="20" height="14" rx="2" />
                  <path d="M2 10h20" />
                </svg>
              </div>
              <div class="method-info"><b>Qris</b>
                <p>Pay with scan QRIS</p>
              </div>
            </div>

            <div class="method-option" data-method="E-Wallet" onclick="selectMethod(this)">
              <div class="method-dot"></div>
              <div class="method-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 12V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h14a2 2 0 002-2v-5z" />
                  <circle cx="16" cy="12" r="1" fill="currentColor" />
                </svg>
              </div>
              <div class="method-info"><b>E-Wallet</b>
                <p>Dana, OVO, Gopay, etc.</p>
              </div>
            </div>

            <div class="method-extra" id="extra-ewallet">
              <label>E-Wallet Provider</label>
              <input type="text" id="inp-ewallet" placeholder="Enter e-wallet provider (e.g., Dana, OVO, Gopay)">
            </div>

            <div class="method-option" data-method="Bank Transfer" onclick="selectMethod(this)">
              <div class="method-dot"></div>
              <div class="method-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 10v11M12 10v11M16 10v11" />
                </svg>
              </div>
              <div class="method-info"><b>Bank Transfer</b>
                <p>Transfer via bank</p>
              </div>
            </div>

            <div class="method-extra" id="extra-bank">
              <label>Bank Name</label>
              <input type="text" id="inp-bank" placeholder="Enter bank name (e.g., BCA, Mandiri, BNI)"
                oninput="clearBankError()">
              <div class="err-msg" id="err-bank">Please enter your bank name</div>
            </div>
          </div>
        </div>

        <div class="payment-summary-card">
          <h3>Payment Summary</h3>
          <div id="paymentSummaryRows"></div>
          <div class="summary-total" style="margin-top:20px">
            <span>Total Amount</span>
            <span class="total-price" id="payTotalPrice">Rp 0</span>
          </div>
          <button class="btn-pay" onclick="proceedPay()">Pay Now</button>
        </div>
      </div>
    </div>
  </div>

  <div class="screen" id="screen-success">
    <div class="success-container">
      <div class="success-card">
        <div class="success-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
        <h2>Pembayaran Berhasil!</h2>
        <p>Tiket Anda sedang disiapkan...</p>
        <p style="margin-top:8px;font-size:0.85rem;color:#94A3B8;">Mengalihkan ke halaman tiket...</p>
      </div>
    </div>
  </div>

  <div class="help-btn">?</div>

  <script>

    const ROUTES = [
      { id: 1, train: 'Kereta Express 101', origin: 'Medan', destination: 'Tebing Tinggi', dep: '08:00', arr: '09:30', dur: '1h 30m', base: 50000 },
      { id: 2, train: 'Kereta Express 102', origin: 'Medan', destination: 'Pematang Siantar', dep: '09:00', arr: '11:45', dur: '2h 45m', base: 75000 },
      { id: 3, train: 'Kereta Lokal 201', origin: 'Tebing Tinggi', destination: 'Pematang Siantar', dep: '10:00', arr: '11:15', dur: '1h 15m', base: 35000 },
      { id: 4, train: 'Kereta Express 103', origin: 'Pematang Siantar', destination: 'Medan', dep: '14:00', arr: '16:45', dur: '2h 45m', base: 75000 },
      { id: 5, train: 'Kereta Lokal 202', origin: 'Pematang Siantar', destination: 'Tebing Tinggi', dep: '15:00', arr: '16:15', dur: '1h 15m', base: 35000 },
      { id: 6, train: 'Kereta Express 104', origin: 'Tebing Tinggi', destination: 'Medan', dep: '17:00', arr: '18:30', dur: '1h 30m', base: 50000 },
      { id: 7, train: 'Kereta Lokal 203', origin: 'Medan', destination: 'Kisaran', dep: '07:00', arr: '09:30', dur: '2h 30m', base: 55000 },
      { id: 8, train: 'Kereta Express 105', origin: 'Medan', destination: 'Rantau Prapat', dep: '06:00', arr: '09:15', dur: '3h 15m', base: 90000 },
      { id: 9, train: 'Kereta Lokal 204', origin: 'Kisaran', destination: 'Medan', dep: '11:00', arr: '13:30', dur: '2h 30m', base: 55000 },
      { id: 10, train: 'Kereta Express 106', origin: 'Rantau Prapat', destination: 'Medan', dep: '12:00', arr: '15:15', dur: '3h 15m', base: 90000 },
      { id: 11, train: 'Kereta Lokal 205', origin: 'Kisaran', destination: 'Rantau Prapat', dep: '10:00', arr: '11:00', dur: '1h 00m', base: 25000 },
      { id: 12, train: 'Kereta Lokal 206', origin: 'Rantau Prapat', destination: 'Kisaran', dep: '13:00', arr: '14:00', dur: '1h 00m', base: 25000 },
      { id: 13, train: 'Kereta Lokal 207', origin: 'Tebing Tinggi', destination: 'Kisaran', dep: '08:30', arr: '10:00', dur: '1h 30m', base: 40000 },
      { id: 14, train: 'Kereta Lokal 208', origin: 'Kisaran', destination: 'Pematang Siantar', dep: '09:00', arr: '10:15', dur: '1h 15m', base: 30000 },
    ];

    function findRoute(origin, destination) {
      return ROUTES.find(r => r.origin === origin && r.destination === destination) || null;
    }


    let currentStep = 1;
    const totalSteps = 4;
    let currentScreen = 'booking';

    const booking = {
      name: '', passengers: 1, origin: '', destination: '', date: '',
      trainName: '', departureTime: '', arrivalTime: '', duration: '',
      className: '', price: 0, basePrice: 0,
      seats: [], paymentMethod: '', ticketId: ''
    };

    const seatRows = ['A', 'B', 'C', 'D'];
    const seatCols = [1, 2, 3, 4];
    const unavailableSeats = ['B2', 'C3'];


    function init() {
      renderSteps();
      renderSeats();
      updateActions();
    }


    function updateClassPrices() {
      const route = findRoute(booking.origin, booking.destination);
      const badge = document.getElementById('routeInfoBadge');

      if (route) {
        booking.basePrice = route.base;
        booking.trainName = route.train;
        booking.departureTime = route.dep;
        booking.arrivalTime = route.arr;
        booking.duration = route.dur;

        document.getElementById('price-Economy').textContent = 'Rp ' + route.base.toLocaleString('id-ID');
        document.getElementById('price-Business').textContent = 'Rp ' + (route.base * 1.5).toLocaleString('id-ID');
        document.getElementById('price-Executive').textContent = 'Rp ' + (route.base * 2).toLocaleString('id-ID');

        badge.style.display = 'flex';
        document.getElementById('routeInfoText').textContent =
          `${route.train} · ${booking.origin} → ${booking.destination} · Dep ${route.dep} · ${route.dur}`;
      } else {
        document.getElementById('price-Economy').textContent = 'Rp -';
        document.getElementById('price-Business').textContent = 'Rp -';
        document.getElementById('price-Executive').textContent = 'Rp -';
        badge.style.display = 'none';
      }

      document.querySelectorAll('.class-option').forEach(o => o.classList.remove('selected'));
      booking.className = '';
      booking.price = 0;
    }

    function renderSteps() {
      const row = document.getElementById('stepsRow');
      row.innerHTML = '';
      for (let i = 1; i <= totalSteps; i++) {
        const el = document.createElement('div');
        el.className = 'step-circle';
        if (i < currentStep) el.classList.add('done');
        else if (i === currentStep) el.classList.add('active');
        else el.classList.add('inactive');
        el.innerHTML = i < currentStep
          ? `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>`
          : i;
        row.appendChild(el);
      }
      document.getElementById('stepLabel').textContent = `Step ${currentStep} of ${totalSteps}`;
    }

    function renderSeats() {
      const grid = document.getElementById('seatsGrid');
      grid.innerHTML = '';
      seatRows.forEach(r => {
        seatCols.forEach(c => {
          const id = r + c;
          const btn = document.createElement('button');
          btn.className = 'seat-btn';
          btn.dataset.seat = id;
          if (unavailableSeats.includes(id)) { btn.classList.add('unavailable'); btn.disabled = true; }
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M5 10V6a2 2 0 012-2h10a2 2 0 012 2v4M3 18h18M5 10h14l1 8H4l1-8z"/>
        </svg>${id}`;
          btn.onclick = () => toggleSeat(btn, id);
          grid.appendChild(btn);
        });
      });
    }

    function toggleSeat(btn, id) {
      const max = parseInt(booking.passengers) || 1;
      if (booking.seats.includes(id)) {
        booking.seats = booking.seats.filter(s => s !== id);
        btn.classList.remove('selected');
      } else {
        if (booking.seats.length >= max) { showToast(`You can only select ${max} seat(s)`); return; }
        booking.seats.push(id);
        btn.classList.add('selected');
      }
      document.getElementById('seatCount').textContent = booking.seats.length;
      document.getElementById('seatMax').textContent = max;
    }

    function selectClass(el) {
      const route = findRoute(booking.origin, booking.destination);
      if (!route) { showToast('Route not found'); return; }
      document.querySelectorAll('.class-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
      booking.className = el.dataset.class;
      const mult = { Economy: 1, Business: 1.5, Executive: 2 };
      booking.price = Math.round(route.base * mult[booking.className]);
    }

    function selectMethod(el) {
      document.querySelectorAll('.method-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
      booking.paymentMethod = el.dataset.method;
      document.getElementById('extra-ewallet').classList.remove('show');
      document.getElementById('extra-bank').classList.remove('show');
      clearBankError();
      if (booking.paymentMethod === 'E-Wallet') document.getElementById('extra-ewallet').classList.add('show');
      else if (booking.paymentMethod === 'Bank Transfer') document.getElementById('extra-bank').classList.add('show');
    }

    function clearBankError() {
      document.getElementById('inp-bank').classList.remove('error');
      document.getElementById('err-bank').classList.remove('show');
    }

    function nextStep() {
      if (currentStep === 1) {
        booking.name = document.getElementById('inp-name').value.trim();
        booking.passengers = parseInt(document.getElementById('inp-passengers').value) || 1;
        booking.origin = document.getElementById('inp-origin').value;
        booking.destination = document.getElementById('inp-destination').value;
        booking.date = document.getElementById('inp-date').value;

        if (!booking.name) return showToast('Please enter your full name');
        if (!booking.origin) return showToast('Please select origin');
        if (!booking.destination) return showToast('Please select destination');
        if (booking.origin === booking.destination) return showToast('Origin and destination cannot be the same');
        if (!booking.date) return showToast('Please select departure date');

        const route = findRoute(booking.origin, booking.destination);
        if (!route) return showToast(`No train available for ${booking.origin} → ${booking.destination}`);
        updateClassPrices();
      }

      if (currentStep === 2) {
        if (!booking.className) return showToast('Please select a class');
      }

      if (currentStep === 3) {
        if (booking.seats.length < booking.passengers)
          return showToast(`Please select ${booking.passengers} seat(s)`);
      }

      if (currentStep === 4) { showPaymentScreen(); return; }

      document.getElementById(`step${currentStep}`).style.display = 'none';
      currentStep++;
      document.getElementById(`step${currentStep}`).style.display = 'block';

      if (currentStep === 3) {
        document.getElementById('seatCount').textContent = booking.seats.length;
        document.getElementById('seatMax').textContent = booking.passengers;
      }
      if (currentStep === 4) renderBookingSummary();

      renderSteps();
      updateActions();
    }

    function prevStep() {
      if (currentScreen === 'payment') { showBookingScreen(); return; }
      if (currentStep === 1) return;
      document.getElementById(`step${currentStep}`).style.display = 'none';
      currentStep--;
      document.getElementById(`step${currentStep}`).style.display = 'block';
      renderSteps();
      updateActions();
    }

    function updateActions() {
      document.getElementById('prevBtn').style.display = currentStep > 1 ? 'block' : 'none';
      document.getElementById('nextBtn').textContent = currentStep === 4 ? 'Proceed to Payment' : 'Next';
    }

    function renderBookingSummary() {
      const total = booking.price * booking.passengers;
      document.getElementById('totalPrice').textContent = 'Rp ' + total.toLocaleString('id-ID');
      document.getElementById('bookingSummary').innerHTML = `
      <div class="summary-row"><span>Passenger Name</span><span>${booking.name}</span></div>
      <div class="summary-row"><span>Route</span><span>${booking.origin} → ${booking.destination}</span></div>
      <div class="summary-row"><span>Train</span><span>${booking.trainName}</span></div>
      <div class="summary-row"><span>Departure</span><span>${booking.date} at ${booking.departureTime}</span></div>
      <div class="summary-row"><span>Arrival</span><span>${booking.arrivalTime} (${booking.duration})</span></div>
      <div class="summary-row"><span>Class</span><span>${booking.className}</span></div>
      <div class="summary-row"><span>Passengers</span><span>${booking.passengers} person(s)</span></div>
      <div class="summary-row"><span>Seats</span><span>${booking.seats.join(', ')}</span></div>
    `;
    }

    function showPaymentScreen() {
      document.getElementById('screen-booking').classList.remove('active');
      document.getElementById('screen-payment').classList.add('active');
      currentScreen = 'payment';

      const total = booking.price * booking.passengers;
      document.getElementById('payTotalPrice').textContent = 'Rp ' + total.toLocaleString('id-ID');
      document.getElementById('paymentSummaryRows').innerHTML = `
      <div class="summary-row"><span>Route</span><span>${booking.origin} → ${booking.destination}</span></div>
      <div class="summary-row"><span>Train</span><span>${booking.trainName}</span></div>
      <div class="summary-row"><span>Class</span><span>${booking.className}</span></div>
      <div class="summary-row"><span>Passengers</span><span>${booking.passengers} person(s)</span></div>
      <div class="summary-row"><span>Seats</span><span>${booking.seats.join(', ')}</span></div>
    `;
    }

    function showBookingScreen() {
      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      document.getElementById('screen-booking').classList.add('active');
      currentScreen = 'booking';
    }
    async function proceedPay() {
      if (!booking.paymentMethod) return showToast('Please select a payment method');

      if (booking.paymentMethod === 'Bank Transfer') {
        const bankVal = document.getElementById('inp-bank').value.trim();
        if (!bankVal) {
          document.getElementById('inp-bank').classList.add('error');
          document.getElementById('err-bank').classList.add('show');
          return;
        }
        booking.bankName = bankVal;
      }

      if (booking.paymentMethod === 'E-Wallet') {
        booking.ewalletProvider = document.getElementById('inp-ewallet').value.trim();
      }

      booking.ticketId = 'TRN-' + Date.now();

      const route = findRoute(booking.origin, booking.destination);
      if (!route) return showToast("Route tidak ditemukan");

      const userId = localStorage.getItem('user_id');
      if (!userId) {
        showToast('Sesi habis, silakan login ulang');
        setTimeout(() => window.location.href = 'login.html', 1500);
        return;
      }

      try {
        const res = await fetch("http://localhost:3000/ticket", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            user_id: userId,
            jadwal_id: route.id,
            seat: booking.seats.join(","),
            class: booking.className,
            passengers: booking.passengers,
            payment_method: booking.paymentMethod,
            name: booking.name
          })
        });

        const data = await res.json();
        console.log("RESPON BACKEND:", data);

      } catch (err) {
        console.error("ERROR FETCH:", err);
      }

      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      document.getElementById('screen-success').classList.add('active');

      setTimeout(() => {
        window.location.href = 'ticket.html';
      }, 1500);
    }
    function goBack() {
      if (currentScreen === 'success') return;
      if (currentScreen === 'payment') { showBookingScreen(); return; }
      if (currentStep > 1) { prevStep(); return; }
      window.location.href = 'dashboard.html';
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    init();
  </script>
</body>

</html>